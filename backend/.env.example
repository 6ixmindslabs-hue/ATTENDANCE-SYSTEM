# Preferred: paste your Supabase connection string here.
# Recommended for this FastAPI backend: Supavisor Session pooler or Direct connection.
# Examples:
# SUPABASE_DATABASE_URL=postgresql://postgres.your_project_ref:your_password@aws-0-your-region.pooler.supabase.com:5432/postgres
# SUPABASE_DATABASE_URL=postgresql://postgres:your_password@db.your_project_ref.supabase.co:5432/postgres
SUPABASE_DATABASE_URL=

# Local fallback if SUPABASE_DATABASE_URL is empty.
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/attendance_system
DATABASE_SSLMODE=
DATABASE_CONNECT_TIMEOUT=5
SECRET_KEY=replace_with_a_long_random_secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
FACE_RECOGNITION_THRESHOLD=0.40
FACE_RECOGNITION_MIN_MARGIN=0.03
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ADMIN_EMAIL=admin@mpnmjec.ac.in
ADMIN_PASSWORD=ChangeMe123!
